# ============================================================
# QuensultingAI Dental Clinic — AI Voice Agent
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- App ---
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0

# --- RetellAI ---
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=your_retell_agent_id_here
RETELL_WEBHOOK_SECRET=your_retell_webhook_secret_here

# --- Google Sheets ---
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheets_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
EMAIL_FROM_NAME=QuensultingAI Dental Clinic
EMAIL_FROM_ADDRESS=your_email@gmail.com

# --- Clinic Config ---
CLINIC_NAME=QuensultingAI Dental Clinic
CLINIC_PHONE=+1234567890
CLINIC_ADDRESS=123 Dental Ave, Suite 100, New York, NY 10001
TRANSFER_PHONE_NUMBER=+1234567890

# --- Logging ---
LOG_LEVEL=INFO
